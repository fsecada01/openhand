# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=
# Intake extraction (feeds the deterministic engine — keep strong).
ANTHROPIC_MODEL=claude-opus-4-8
# Explanation pass (constrained rewording — a lighter model is fine).
ANTHROPIC_EXPLAIN_MODEL=claude-sonnet-5
DATABASE_URL=sqlite:///./openhand.db
# Required by sqlmodel-crud-utilities at import time.
SQL_DIALECT=sqlite
# Privacy: keep false outside local debugging.
STORE_NARRATIVES=false
RATE_LIMIT_SCREEN=10/minute
