{#def status #}
{# Human labels, not bureaucratic enum names: what should I *do*
   with this result? Still hedged — these are estimates. #}
{% set display = {
    "likely_eligible": ("badge-success", "Strong match"),
    "possibly_eligible": ("badge-warning", "Worth applying"),
    "likely_ineligible": ("badge-error", "Unlikely match"),
    "undetermined": ("badge-neutral", "Can't tell yet"),
} %}
{% set cls, label = display.get(status, ("badge-neutral", status)) %}
<span class="badge whitespace-nowrap font-medium {{ cls }}">
  {{ label }}
</span>
