{#def explanation, determinations, resource_searches=None, prior_narrative="", profile_json="", round_num=1, offer_feedback=True #}
<h2 class="text-2xl font-bold mb-3 flex items-center gap-2">
  <span aria-hidden="true">✅</span> What we found
</h2>
<ExplanationCard :explanation="explanation" />

<h3 class="text-xl font-semibold mb-3">Program details</h3>
<div class="grid gap-4 sm:grid-cols-2">
  {% for d in determinations %}
  <DeterminationCard :d="d" />
  {% endfor %}
</div>

{% if resource_searches %}
<ResourceSearchCard :resource_searches="resource_searches" />
{% endif %}

<p class="text-xs opacity-60 mt-6 text-center">
  These are screening estimates based on published federal guidelines
  &mdash; only the agency that runs each program can make a decision.
  Your local mutual aid network remains a great option for needs
  these programs don't cover.
</p>

<FeedbackForm :prior_narrative="prior_narrative"
              :round_num="round_num"
              :profile_json="profile_json"
              :offer_feedback="offer_feedback" />
