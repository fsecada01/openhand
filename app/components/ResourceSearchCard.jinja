{#def resource_searches #}
<div class="card bg-base-100 border border-dashed border-warning/50
            mt-6 shadow-sm">
  <div class="card-body">
    <h3 class="card-title text-base flex-wrap gap-2">
      <span aria-hidden="true">🔎</span> Other resources to check
      <span class="badge badge-outline badge-warning">as-is, unverified</span>
    </h3>
    <p class="text-xs opacity-70 mb-2">
      These came from a web search &mdash; for programs that didn't
      screen as a strong federal match, and for anything else you
      asked about: state assistance programs, local mutual aid
      networks, and grant-based private assistance. We haven't vetted
      these; check details yourself before relying on them.
    </p>
    {% for search in resource_searches %}
    <h4 class="font-semibold text-sm mt-3">{{ search.program_name }}</h4>
    <ul class="list-disc ml-5 text-sm">
      {% for r in search.results %}
      <li>
        <a class="link link-primary" href="{{ r.url }}" target="_blank"
           rel="noopener">{{ r.title }}</a>
        {% if r.snippet %}
        <details class="inline">
          <summary class="cursor-pointer text-xs opacity-70 inline">
            {{ r.snippet | truncate(140, False, "…") }}
          </summary>
          <span class="block text-xs opacity-70 mt-1">{{ r.snippet }}</span>
        </details>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% endfor %}
  </div>
</div>
