{#def prior_narrative, round_num=1, confirm_round=1, headline="Before we show your results", body="did we miss anything?" #}
<div class="card bg-base-100 shadow-lg border border-base-300/60">
  <div class="card-body">
    <div class="grid grid-cols-[auto_1fr] gap-3 items-start">
      <span class="flex h-9 w-9 items-center justify-center
                   rounded-full bg-primary/15 text-lg"
            aria-hidden="true">🤲</span>
      <div class="rounded-2xl rounded-tl-sm bg-primary/10 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide
                  opacity-60 mb-1">{{ headline }}</p>
        {# Uppercase only the first letter — the prompts read as
           "headline — body" so bodies arrive lowercase, but
           `capitalize` would also flatten mid-string capitals
           ("For example:"). #}
        <p>{{ body[0] | upper ~ body[1:] }}</p>
      </div>
    </div>
    <Form action="/screen">
      <input type="hidden" name="prior_narrative"
             value="{{ prior_narrative }}">
      <input type="hidden" name="round_num" value="{{ round_num }}">
      <input type="hidden" name="confirm_round"
             value="{{ confirm_round }}">
      <textarea name="narrative"
                class="textarea textarea-bordered w-full mt-3
                       focus:textarea-primary transition-colors"
                placeholder="Anything to add? (optional)"></textarea>
      <div class="card-actions justify-between items-center mt-3">
        <button type="submit" name="confirmed" value="1" formnovalidate
                class="btn btn-ghost btn-sm">
          No, that's everything &mdash; show my results
        </button>
        <SubmitButton label="Add &amp; continue" />
      </div>
    </Form>
  </div>
</div>
